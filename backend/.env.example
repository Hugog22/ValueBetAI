DATABASE_URL="postgresql://user:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
ODDS_API_KEY="tu_llave_de_odds_api"
API_SPORTS_KEY="tu_llave_de_api_football"
SECRET_KEY="tu_llave_secreta_jwt_para_usuarios"

# ── Smart Scheduler (ajustable desde el panel de Render sin tocar código) ──
# Zona horaria base: Europe/Madrid
# Formato: "minuto hora dia_mes mes dia_semana"

# Días de valle (Lun–Jue): 3 llamadas/día a las 10h, 16h y 22h hora Madrid
CRON_WEEKDAY="0 10,16,22 * * 1-4"

# Días de pico (Vie–Dom): cada hora entre las 12h y las 22h hora Madrid
CRON_WEEKEND="0 12-22 * * 5,6,0"

# Deporte de The Odds API — NO cambiar salvo que amplíes a otras ligas
ODDS_SPORT="soccer_spain_la_liga"
